APP_NAME=RICOX
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000/

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ricox
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu@gmail.com
MAIL_PASSWORD=tu_contraseña_de_app_gmail
MAIL_FROM_ADDRESS="tu@gmail.com"
MAIL_FROM_NAME="RICOX"

VITE_APP_NAME="${APP_NAME}"

# API de tipos de cambio — https://exchangerate-api.com (gratis)
EXCHANGE_RATE_API_KEY=

# Email del administrador (acceso durante modo mantenimiento)
ADMIN_EMAIL=tu@gmail.com

# API de Claude para el Asistente IA — https://console.anthropic.com
ANTHROPIC_API_KEY=

# VAPID para notificaciones push PWA
# Genera con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu@gmail.com